{
  "files.associations": {
    "*.yaml": "yaml",
    "*.yml": "yaml"
  },
  "yaml.schemas": {
    "./schemas/system.schema.json": "architecture/*/system.yaml",
    "./schemas/networks.schema.json": "architecture/networks.yaml",
    "./schemas/deployment.schema.json": "architecture/*/deployments/*.yaml",
    "./schemas/provenance.schema.json": "architecture/*/provenance.yaml"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.autoIndent": "advanced"
  },
  "files.exclude": {
    "**/.git": true
  }
}
