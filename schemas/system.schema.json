{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Michael-JRead/Doc2ArchAgent/schemas/system.schema.json",
  "title": "Doc2ArchAgent System YAML Schema",
  "description": "Schema for architecture/*/system.yaml — the core C4 architecture model.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "description": "System-level metadata.",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["proposed", "active", "deprecated", "decommissioned"]
        },
        "compliance_frameworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.95,
          "description": "Minimum extraction confidence (0.0–1.0) for including entities. Default 0.95."
        }
      },
      "required": ["name", "description", "owner", "status"],
      "additionalProperties": true
    },
    "contexts": {
      "type": "array",
      "description": "C4 Level 1 — System contexts.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "internal": { "type": "boolean" },
          "external_system_id": { "type": "string" },
          "out_of_scope": { "type": "boolean", "default": false, "description": "If true, threat rules skip this context." }
        },
        "required": ["id", "name", "description", "internal"],
        "additionalProperties": true
      }
    },
    "context_relationships": {
      "type": "array",
      "description": "Relationships between contexts.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "source_context": { "type": "string" },
          "target_context": { "type": "string" },
          "label": { "type": "string" },
          "bidirectional": { "type": "boolean" }
        },
        "required": ["id", "source_context", "target_context", "label"],
        "additionalProperties": true
      }
    },
    "containers": {
      "type": "array",
      "description": "C4 Level 2 — Containers within contexts.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "context_id": { "type": "string" },
          "container_type": {
            "type": "string",
            "enum": [
              "api_gateway", "application_server", "web_app", "database",
              "message_queue", "cache", "file_storage", "cdn",
              "reverse_proxy", "load_balancer", "batch_processor",
              "stream_processor", "search_engine", "monitoring",
              "logging", "identity_provider", "other"
            ]
          },
          "technology": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proposed", "active", "deprecated", "decommissioned"]
          },
          "out_of_scope": { "type": "boolean", "default": false }
        },
        "required": ["id", "name", "context_id", "container_type", "technology"],
        "additionalProperties": true
      }
    },
    "container_relationships": {
      "type": "array",
      "description": "Relationships between containers.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "source_container": { "type": "string" },
          "target_container": { "type": "string" },
          "label": { "type": "string" },
          "synchronous": { "type": "boolean" },
          "data_classification": {
            "type": "string",
            "enum": ["public", "internal", "confidential", "restricted"]
          },
          "usage": {
            "type": "string",
            "enum": ["business", "devops", "monitoring"],
            "default": "business",
            "description": "Flow purpose. DevOps/monitoring flows receive lower threat severity."
          }
        },
        "required": ["id", "source_container", "target_container", "label"],
        "additionalProperties": true
      }
    },
    "components": {
      "type": "array",
      "description": "C4 Level 3 — Components within containers.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "container_id": { "type": "string" },
          "component_type": {
            "type": "string",
            "enum": [
              "api", "service", "database", "cache", "message_consumer",
              "message_producer", "scheduled_task", "web_frontend",
              "worker", "proxy", "function", "health_check",
              "metrics", "other"
            ]
          },
          "technology": { "type": "string", "minLength": 1 },
          "platform": { "type": "string" },
          "resiliency": { "type": "string" },
          "multi_tenant": {
            "type": "boolean",
            "default": false,
            "description": "Multi-tenant components require stronger authentication."
          },
          "out_of_scope": { "type": "boolean", "default": false },
          "encryption_at_rest": {
            "type": "string",
            "enum": ["none", "aes-256", "rsa", "envelope", "platform_managed", "customer_managed"],
            "description": "At-rest encryption for data-storing components."
          },
          "availability": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Availability requirement. Critical components trigger DoS risk rules."
          },
          "integrity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Integrity requirement. Critical components trigger tampering risk rules."
          },
          "listeners": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "protocol": { "type": "string", "minLength": 1 },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "tls_enabled": { "type": "boolean" },
                "tls_version_min": { "type": "string" },
                "authn_mechanism": {
                  "type": "string",
                  "enum": [
                    "none", "api_key", "basic", "oauth2", "oidc", "saml",
                    "mtls", "certificate", "jwt", "mfa", "password", "custom"
                  ]
                },
                "authz_required": { "type": "boolean" }
              },
              "required": ["id", "protocol", "port", "tls_enabled", "authn_mechanism", "authz_required"],
              "additionalProperties": true
            }
          }
        },
        "required": ["id", "name", "container_id", "component_type", "technology"],
        "additionalProperties": true
      }
    },
    "component_relationships": {
      "type": "array",
      "description": "Relationships between components.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "source_component": { "type": "string" },
          "target_component": { "type": "string" },
          "target_listener_ref": { "type": "string" },
          "label": { "type": "string" },
          "synchronous": { "type": "boolean" },
          "data_entities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "data_classification": {
            "type": "string",
            "enum": ["public", "internal", "confidential", "restricted"]
          },
          "usage": {
            "type": "string",
            "enum": ["business", "devops", "monitoring"],
            "default": "business"
          }
        },
        "required": ["id", "source_component", "target_component", "label"],
        "additionalProperties": true
      }
    },
    "external_systems": {
      "type": "array",
      "description": "External systems referenced by contexts or relationships.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "category": { "type": "string" }
        },
        "required": ["id", "name"],
        "additionalProperties": true
      }
    },
    "data_entities": {
      "type": "array",
      "description": "Data entities referenced in component relationships.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": ["public", "internal", "confidential", "restricted"]
          }
        },
        "required": ["id", "name"],
        "additionalProperties": true
      }
    },
    "trust_boundaries": {
      "type": "array",
      "description": "Trust boundaries between network zones.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "source_zone": { "type": "string" },
          "target_zone": { "type": "string" }
        },
        "required": ["id", "name", "source_zone", "target_zone"],
        "additionalProperties": true
      }
    },
    "accepted_risks": {
      "type": "array",
      "description": "Risks reviewed and accepted by stakeholders.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
          "finding_pattern": { "type": "string", "description": "Rule ID or finding category to suppress." },
          "entity_id": { "type": "string", "description": "Specific entity this acceptance applies to." },
          "justification": { "type": "string", "minLength": 10 },
          "accepted_by": { "type": "string", "minLength": 1 },
          "review_date": { "type": "string", "format": "date" },
          "expires": { "type": "string", "format": "date" }
        },
        "required": ["id", "finding_pattern", "justification", "accepted_by", "review_date"],
        "additionalProperties": true
      }
    }
  },
  "required": ["metadata"],
  "additionalProperties": true
}
