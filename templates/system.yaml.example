# Example system.yaml — Payment Processing Platform
# This file is generated by the @architect agent.
# Path: architecture/<system-id>/system.yaml

metadata:
  name: Payment Processing Platform
  description: Handles card-present and card-not-present payment transactions
  owner: Platform Security Team
  status: active
  compliance_frameworks:
    - PCI-DSS
    - SOC2
    - GDPR

# Layer 1 — Contexts
contexts:
  - id: payment-platform
    name: Payment Platform
    description: Core payment processing system
    internal: true

  - id: card-network
    name: Visa / Mastercard Network
    description: External card network for transaction authorization
    internal: false
    external_system_id: visa-mastercard

# Context Relationships
context_relationships:
  - id: payment-to-card-network
    source_context: payment-platform
    target_context: card-network
    label: "submits transactions to"
    bidirectional: false

# Layer 2 — Containers
containers:
  - id: api-tier
    name: API Tier
    context_id: payment-platform
    container_type: api_gateway
    technology: Kong Gateway
    description: Public-facing API gateway with rate limiting
    status: active

  - id: app-core
    name: Application Core
    context_id: payment-platform
    container_type: application_server
    technology: Java / Spring Boot
    description: Business logic for payment processing
    status: active

  - id: data-tier
    name: Data Tier
    context_id: payment-platform
    container_type: database
    technology: PostgreSQL 15
    description: Persistent storage for transactions and accounts
    status: active

# Container Relationships
container_relationships:
  - id: api-to-app
    source_container: api-tier
    target_container: app-core
    label: "routes requests to"
    synchronous: true
    data_classification: confidential

  - id: app-to-data
    source_container: app-core
    target_container: data-tier
    label: "reads/writes transaction data"
    synchronous: true
    data_classification: confidential

# Layer 3 — Components
components:
  - id: payment-api
    name: Payment API
    container_id: app-core
    component_type: api
    technology: Spring Boot 3.2
    platform: JVM 21
    resiliency: active-active
    listeners:
      - id: payment-api-https
        protocol: HTTPS
        port: 8443
        tls_enabled: true
        tls_version_min: "1.3"
        authn_mechanism: oauth2
        authz_required: true

  - id: payment-db
    name: Payment Database
    container_id: data-tier
    component_type: database
    technology: PostgreSQL 15
    platform: Linux
    resiliency: primary-replica
    listeners:
      - id: payment-db-pg
        protocol: PostgreSQL
        port: 5432
        tls_enabled: true
        tls_version_min: "1.2"
        authn_mechanism: certificate
        authz_required: true

# Component Relationships
component_relationships:
  - id: api-to-db
    source_component: payment-api
    target_component: payment-db
    target_listener_ref: payment-db-pg
    label: "persists transactions"
    synchronous: true
    data_entities:
      - transaction-record
    data_classification: confidential

# External Systems
external_systems:
  - id: visa-mastercard
    name: Visa / Mastercard Network
    description: Card network for payment authorization
    category: partner

# Data Entities (optional)
data_entities:
  - id: transaction-record
    name: Transaction Record
    description: Payment transaction with card details
    classification: confidential

# Trust Boundaries (optional)
trust_boundaries:
  - id: internet-to-dmz
    name: Internet to DMZ
    description: Boundary between public internet and DMZ network
    source_zone: internet
    target_zone: dmz
